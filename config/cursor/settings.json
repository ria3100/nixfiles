{
	// ─── Editor ───
	"editor.tabSize": 2,
	"editor.fontSize": 14,
	"editor.fontFamily": "UDEV Gothic NFLG",
	"editor.folding": false,
	"editor.rulers": [80, 100],
	"editor.cursorBlinking": "smooth",
	"editor.roundedSelection": false,
	"editor.renderWhitespace": "all",
	"editor.copyWithSyntaxHighlighting": false,
	"editor.accessibilitySupport": "off",

	// ─── Editor: 補完・入力 ───
	"editor.tabCompletion": "off",
	"editor.snippetSuggestions": "inline",
	"editor.suggestSelection": "first",
	"editor.inlineSuggest.enabled": true,
	"editor.autoClosingBrackets": "never",
	"editor.multiCursorModifier": "ctrlCmd",

	// ─── Editor: フォーマット ───
	"editor.formatOnPaste": true,
	"editor.formatOnSave": true,
	"editor.defaultFormatter": "oxc.oxc-vscode",

	// ─── Editor: 検索 ───
	"editor.find.cursorMoveOnType": false,

	// ─── Editor: ミニマップ ───
	"editor.minimap.enabled": true,
	"editor.minimap.maxColumn": 60,

	// ─── Files ───
	"files.insertFinalNewline": true,
	"files.exclude": {
		"/.git": true,
		"/.DS_Store": true,
		"/node_modules": true,
		"/node_modules/": true
	},
	"files.watcherExclude": {
		"/node_modules/": true,
		"**/.git/objects/**": true,
		"**/node_modules/**": true
	},

	// ─── Search ───
	"search.exclude": {
		"**/.next": true,
		"**/node_modules": true,
		"**/pnpm-lock.yaml": true,
		"target": true
	},
	"search.globalFindClipboard": true,
	"search.showLineNumbers": true,

	// ─── Explorer ───
	"explorer.confirmDelete": false,
	"explorer.confirmDragAndDrop": false,
	"explorer.confirmPasteNative": false,
	"explorer.enableUndo": false,

	// ─── Workbench: テーマ・UI ───
	"workbench.colorTheme": "Monokai",
	"workbench.iconTheme": "material-icon-theme",
	"workbench.startupEditor": "newUntitledFile",
	"workbench.statusBar.visible": true,
	"workbench.activityBar.orientation": "vertical",
	"workbench.list.horizontalScrolling": true,

	// ─── Workbench: タブ ───
	"workbench.editor.tabCloseButton": "off",
	"workbench.editor.tabActionCloseVisibility": false,
	"workbench.editor.enablePreviewFromQuickOpen": false,
	"workbench.editor.customLabels.patterns": {
		"**/{index,page,layout,utils,types}.{ts,tsx}": "${dirname}/${filename}.${extname}"
	},
	// ─── Workbench: カスタムカラー ───
	"workbench.colorCustomizations": {
		"editor.background": "#1e1f1a", // エディタ背景
		"editorGroupHeader.tabsBackground": "#1e1f1a", // タブバー背景
		"sideBar.background": "#232420", // サイドバー背景
		"sideBarSectionHeader.background": "#272822", // サイドバーセクション見出し
		"titleBar.activeBackground": "#272822", // タイトルバー（アクティブ）
		"titleBar.inactiveBackground": "#1e1f1a", // タイトルバー（非アクティブ）
		"tab.activeBackground": "#272822", // アクティブタブ
		"tab.inactiveBackground": "#1e1f1a", // 非アクティブタブ
		"activityBar.background": "#1e1f1a", // アクティビティバー背景
		"panel.background": "#1e1f1a", // パネル（ターミナル等）背景
		"statusBar.background": "#1e1f1a", // ステータスバー背景
		"integratedTerminal.ansiColors.cyan": "#00c5c7", // ターミナル: シアン
		"integratedTerminal.ansiColors.red": "#f92a72", // ターミナル: レッド
		"integratedTerminal.ansiColors.blue": "#66d9ef" // ターミナル: ブルー
	},

	// ─── Window ───
	"window.openFilesInNewWindow": "off",
	"window.newWindowDimensions": "inherit",
	"window.title": "${rootName}",

	// ─── Terminal ───
	"terminal.integrated.defaultProfile.osx": "zsh",
	"terminal.integrated.defaultLocation": "editor",
	"terminal.integrated.tabs.location": "left",
	"terminal.integrated.lineHeight": 1,
	"terminal.integrated.fontSize": 14,
	"terminal.integrated.cursorBlinking": true,
	"terminal.integrated.cursorStyle": "line",
	"terminal.integrated.cursorWidth": 2,
	"terminal.integrated.fontWeightBold": "normal",
	"terminal.integrated.scrollback": 10000,
	"terminal.integrated.copyOnSelection": true,

	// ─── Git ───
	"git.autofetch": true,
	"git.confirmSync": false,
	"git.ignoreRebaseWarning": true,
	"git.mergeEditor": false,
	"git.openRepositoryInParentFolders": "never",

	// ─── Linter / Formatter ───
	"oxc.enable": true,

	// ─── JavaScript / TypeScript ───
	"javascript.updateImportsOnFileMove.enabled": "always",
	"typescript.updateImportsOnFileMove.enabled": "always",
	"javascript.suggest.autoImports": true,
	"typescript.suggest.autoImports": true,
	"javascript.validate.enable": false,
	"typescript.preferGoToSourceDefinition": true,
	"typescript.inlayHints.functionLikeReturnTypes.enabled": true,
	"javascript.inlayHints.functionLikeReturnTypes.enabled": true,
	"javascript.inlayHints.variableTypes.enabled": true,
	"javascript.inlayHints.parameterTypes.enabled": true,
	"javascript.inlayHints.propertyDeclarationTypes.enabled": true,

	// ─── 言語別設定 ───
	"[rust]": {
		"editor.formatOnSave": true,
		"editor.formatOnPaste": true,
		"editor.formatOnType": true,
		"editor.defaultFormatter": "rust-lang.rust-analyzer"
	},
	"[python]": {
		"editor.formatOnType": true
	},
	"[dockercompose]": {
		"editor.insertSpaces": true,
		"editor.tabSize": 2,
		"editor.autoIndent": "advanced",
		"editor.defaultFormatter": "redhat.vscode-yaml"
	},
	"[github-actions-workflow]": {
		"editor.defaultFormatter": "redhat.vscode-yaml"
	},

	// ─── GitHub PR ───
	"githubPullRequests.pullBranch": "never",
	"githubPullRequests.createOnPublishBranch": "never",
	"githubPullRequests.commentExpandState": "collapseAll",

	// ─── その他 ───
	"security.workspace.trust.untrustedFiles": "open",
	"update.showReleaseNotes": false,
	"debug.console.fontSize": 14,

	// ─── Cursor ───
	"cursor.composer.textSizeScale": 1.15,
	"cursor.composer.usageSummaryDisplay": "always",
}
